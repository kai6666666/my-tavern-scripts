    "findRegex": "<骰子商店API测试>",
    "replaceString": "<div data-acu-gacha-regex='all' style='display:grid;gap:10px;max-width:760px;margin:8px 0;padding:14px;border:1px solid #8b8a70;border-radius:10px;background:#102426;color:#f2ead0;box-shadow:0 10px 28px rgba(0,0,0,.28);font:13px/1.5 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;box-sizing:border-box'>\n  <div style='display:flex;align-items:center;justify-content:space-between;gap:10px;padding-bottom:9px;border-bottom:1px solid #59645b'>\n    <span style='display:grid;gap:1px;min-width:0'>\n      <span style='color:#c9c19a;font-size:11px;font-weight:700;line-height:1.25'>骰子商店</span>\n      <strong style='color:#fff4cf;font-size:16px;font-weight:800;line-height:1.3;letter-spacing:0'>API 测试面板</strong>\n    </span>\n    <span style='flex:0 0 auto;padding:2px 9px;border:1px solid #8b8a70;border-radius:999px;background:#243433;color:#d8d0a8;font-size:11px;font-weight:700;white-space:nowrap'>正则按钮</span>\n  </div>\n  <div style='display:grid;grid-template-columns:minmax(58px,74px) minmax(0,1fr);gap:8px;align-items:start'>\n    <span style='padding-top:6px;color:#c9c19a;font-size:12px;font-weight:800;white-space:nowrap'>商店</span>\n    <span style='display:flex;flex-wrap:wrap;gap:6px;min-width:0'>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='openShop' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 12px;border:1px solid #cdbc86;border-radius:7px;background:#cdbc86;color:#142324;font:700 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>打开商店</span>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='openShardShop' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #77806f;border-radius:7px;background:#253534;color:#f2ead0;font:650 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>碎片商店</span>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='openSettings' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #77806f;border-radius:7px;background:#253534;color:#f2ead0;font:650 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>打开商店设置</span>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='state' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #77806f;border-radius:7px;background:#253534;color:#f2ead0;font:650 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>查看状态</span>\n    </span>\n  </div>\n  <div style='display:grid;grid-template-columns:minmax(58px,74px) minmax(0,1fr);gap:8px;align-items:start'>\n    <span style='padding-top:6px;color:#c9c19a;font-size:12px;font-weight:800;white-space:nowrap'>骰运</span>\n    <span style='display:flex;flex-wrap:wrap;gap:6px;min-width:0'>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='addFortune' data-acu-gacha-amount='100' data-acu-gacha-detail='正则面板 +100' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #77806f;border-radius:7px;background:#253534;color:#f2ead0;font:650 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>+100 骰运</span>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='addFortune' data-acu-gacha-amount='-100' data-acu-gacha-detail='正则面板 -100' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #77806f;border-radius:7px;background:#253534;color:#f2ead0;font:650 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>-100 骰运</span>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='clearFortune' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #b26a6d;border-radius:7px;background:#3a2528;color:#ffd1d1;font:700 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>清空骰运</span>\n    </span>\n  </div>\n  <div style='display:grid;grid-template-columns:minmax(58px,74px) minmax(0,1fr);gap:8px;align-items:start'>\n    <span style='padding-top:6px;color:#c9c19a;font-size:12px;font-weight:800;white-space:nowrap'>抽卡</span>\n    <span style='display:flex;flex-wrap:wrap;gap:6px;min-width:0'>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='singleDraw' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #77806f;border-radius:7px;background:#253534;color:#f2ead0;font:650 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>单抽</span>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='tenDraw' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #77806f;border-radius:7px;background:#253534;color:#f2ead0;font:650 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>十连抽</span>\n    </span>\n  </div>\n  <div style='display:grid;grid-template-columns:minmax(58px,74px) minmax(0,1fr);gap:8px;align-items:start'>\n    <span style='padding-top:6px;color:#c9c19a;font-size:12px;font-weight:800;white-space:nowrap'>测试奖池</span>\n    <span style='display:flex;flex-wrap:wrap;gap:6px;min-width:0'>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='createTestCatalog' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #77806f;border-radius:7px;background:#253534;color:#f2ead0;font:650 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>创建测试奖品</span>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='drawTestCatalog' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #77806f;border-radius:7px;background:#253534;color:#f2ead0;font:650 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>切池并单抽</span>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='listTestCatalog' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #77806f;border-radius:7px;background:#253534;color:#f2ead0;font:650 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>列出测试池</span>\n      <span class='acu-gacha-regex-action' role='button' tabindex='0' data-acu-gacha-action='clearTestCatalog' style='display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:4px 11px;border:1px solid #b26a6d;border-radius:7px;background:#3a2528;color:#ffd1d1;font:700 13px/1.35 \"Segoe UI\",\"Microsoft YaHei\",sans-serif;cursor:pointer;user-select:none;white-space:nowrap;box-sizing:border-box'>清理测试奖池</span>\n    </span>\n  </div>\n</div>",
